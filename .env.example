# DigiPay UPG — credentials for the standalone module.
#
# Copy this file to `.env` and fill in real values (from DigiPay support / the merchant panel).
# `.env` is gitignored — NEVER commit real credentials.
#
#   cp .env.example .env   &&   edit .env

# OAuth client — used to build the `Authorization: Basic base64(client_id:client_secret)`
# header on POST /oauth/token.
DIGIPAY_CLIENT_ID=
DIGIPAY_CLIENT_SECRET=

# Merchant login — sent as form-data on POST /oauth/token (grant_type=password).
DIGIPAY_USERNAME=
DIGIPAY_PASSWORD=

# NOTE: the environment (staging | production) is chosen at runtime, not stored here.
#   - staging:    https://uat.mydigipay.info/digipay/api
#   - production: https://api.mydigipay.com/digipay/api
